# Database (Neon PostgreSQL)
# Obtenir sur: https://neon.tech/ (intégration Vercel disponible)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Better Auth
# Générer une clé secrète avec: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here"
BETTER_AUTH_URL="http://localhost:3000"

# Resend (Emails)
# Obtenir sur: https://resend.com/
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="Motion Finance <noreply@resend.dev>"

# Vercel Blob (Upload)
# Obtenir sur: https://vercel.com/dashboard (Storage > Blob)
# Sur Vercel, cette variable est auto-configurée
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
